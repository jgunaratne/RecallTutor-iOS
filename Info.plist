<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Google Sign-In callback scheme. Replace both REVERSED_CLIENT_ID values
	     below with the REVERSED_CLIENT_ID from your GoogleService-Info.plist
	     (looks like com.googleusercontent.apps.1234567890-abcdef). -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>com.googleusercontent.apps.407579959970-96oq6l4keui1hafshg7ukphv23femqlg</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.407579959970-96oq6l4keui1hafshg7ukphv23femqlg</string>
			</array>
		</dict>
	</array>

	<!-- Export compliance: the app only uses standard HTTPS/TLS network
	     calls and OS-provided Keychain/CryptoKit APIs (a SHA-256 hash for
	     the Sign in with Apple nonce) — no proprietary encryption. This
	     answers the App Store Connect "does your app use non-exempt
	     encryption" prompt so it isn't asked on every build upload. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
</dict>
</plist>
